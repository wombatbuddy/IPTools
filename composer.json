{
  "name": "wombatbuddy/iptools",
  "type": "library",
  "description": "PHP Library for manipulating network addresses (IPv4 and IPv6). Fork of s1lentium/iptools. Fixes PHP 8.5 deprecation warnings.",
  "keywords": [
    "IP-Tools",
    "network",
    "subnet",
    "cidr",
    "IP",
    "IPv4",
    "IPv6"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Safarov Alisher",
      "email": "alisher.safarov@outlook.com",
      "homepage": "https://github.com/S1lentium"
    },
    {
      "name": "Andrey Vitushkin",
      "email": "wombatbuddy@gmail.com",
      "homepage": "https://github.com/wombatbuddy",
      "role": "maintainer"
    }
  ],
  "require": {
    "php": "^8.0",
    "ext-bcmath": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "IPTools\\": "src/"
    }
  }
}
